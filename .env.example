# Copy this file to .env and fill in real values. .env is never committed.

# --- Twilio WhatsApp (required to send/receive real WhatsApp messages) ---
# Get these from console.twilio.com. Without them, the notifier runs in
# CONSOLE mode (messages printed to logs, not sent) - the full loop still
# works locally, just not over real WhatsApp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Fare data source ---
# mock     = MockFareIngestor (default, no credentials needed)
# amadeus  = AmadeusFareIngestor (real GDS fares, requires the two keys below)
# google   = GoogleFlightsIngestor (real fares via Google Flights/fli, no key needed)
# hybrid   = HybridIngestor (Google Flights + Amadeus combined for max coverage)
FARE_SOURCE=mock

# --- Google Flights (only used if FARE_SOURCE=google or hybrid) ---
# No API key needed. Requires: pip install flights (the fli package).
# Uses reverse-engineered Google Flights internal API.
# Best coverage for Nigerian/West African carriers (Air Peace, Arik, Ibom, etc.)
GOOGLE_FLIGHTS_CURRENCY=NGN

# --- Amadeus Self-Service API (only needed if FARE_SOURCE=amadeus) ---
# Free-tier credentials from developers.amadeus.com. Uses the test
# environment by default - see AMADEUS_HOSTNAME to switch to production
# once you have a paid production key.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_HOSTNAME=test.api.amadeus.com

# --- Worker ---
FARE_POLL_MINUTES=15
